---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects', ({data}) => !data.draft);
const projects = all.sort((a,b) => {
  const da = isNaN(Date.parse(a.data.date)) ? 0 : Date.parse(a.data.date);
  const db = isNaN(Date.parse(b.data.date)) ? 0 : Date.parse(b.data.date);
  return db - da;
});
---

<BaseLayout title="Projects — River Primavera Wijaya" activePage="projects">
<div class="main-wrap">

  <div class="page-header">
    <h1 class="page-title">Projects</h1>
    <p class="page-subtitle">Things I've built and a step-by-step guidance or explaination on how I built it.</p>
  </div>

  <div class="feed">
    {projects.map(project => (
      <a href={`/projects/${project.id}`} class="feed-card type-project">
        <div class="feed-card-body">
          <div class="feed-card-meta">
            <span class="feed-card-type">Project</span>
            <span class="feed-card-dot">·</span>
            <span class="feed-card-date">{project.data.date}</span>
          </div>
          <div class="feed-card-title">{project.data.title}</div>
          <div class="feed-card-summary">{project.data.summary}</div>
          <div class="feed-card-tags">
            {project.data.tags.map((t: string) => <span class="feed-card-tag">{t}</span>)}
            {project.data.proud && <span class="feed-card-tag proud">Most proud</span>}
          </div>
        </div>
        {project.data.image
          ? <img src={project.data.image} alt={project.data.title} class="feed-card-thumb" />
          : <div class="feed-card-thumb-placeholder">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
              </svg>
            </div>
        }
      </a>
    ))}
  </div>

</div>
<footer><span>River Primavera Wijaya</span><span>Jakarta · Always learning</span></footer>
</BaseLayout>
